<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/black"
    android:padding="20dp"
    android:paddingTop="48dp"
    tools:context=".MainActivity">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/app_name"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Status Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeColor="#2A2A2A"
        app:strokeWidth="1dp"
        android:onClick="recheckDeviceStatusHandler">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <!-- Left: Status info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mainactivity_textview_root_state"
                        android:textColor="#666666"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/textView_root_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#4CAF50"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mainactivity_textview_xposed_module_state"
                        android:textColor="#666666"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/textView_xposed_module_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#4CAF50"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:id="@+id/textView_magisk_module_version_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mainactivity_textview_magisk_module_state"
                        android:textColor="#666666"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/textView_magisk_module_version"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/textView_app_version_name_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mainactivity_textview_toolsbox_version"
                        android:textColor="#666666"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/textView_app_version_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Hidden device status text for compatibility -->
    <TextView
        android:id="@+id/textView_device_status_text"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:text="@string/mainactivity_textview_device_state" />
    <TextView
        android:id="@+id/textView_root_state_text"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />
    <TextView
        android:id="@+id/textView_xposed_module_state_text"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- Tools Grid: 2 columns -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="2"
        android:rowCount="4"
        android:layout_marginBottom="12dp">

        <!-- Row 1, Col 1: Reset Permission -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#2A2A2A"
            app:strokeWidth="1dp"
            android:onClick="resetPermissionsHandler">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mainactivity_button_reset_app_permission"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tool_desc_reset_permission"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Row 1, Col 2: Fix Permission -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#2A2A2A"
            app:strokeWidth="1dp"
            android:onClick="fixPermissionsHandler">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mainactivity_button_grant_system_app_permission"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tool_desc_fix_permission"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Row 2, Col 1: Clean Cache -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#2A2A2A"
            app:strokeWidth="1dp"
            android:onClick="cleanPackageCacheHandler">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mainactivity_button_clean_package_cache"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tool_desc_clean_cache"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Row 2, Col 2: Reset Restriction -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#2A2A2A"
            app:strokeWidth="1dp"
            android:onClick="resetPackageRestrictionHandler">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mainactivity_button_reset_package_restriction"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tool_desc_reset_restriction"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Row 3, Col 1: Hide Theme -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#2A2A2A"
            app:strokeWidth="1dp"
            android:onClick="hideThemeFolderHandler">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mainactivity_button_hide_theme_folder"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tool_desc_hide_theme"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Row 3, Col 2: Allow System App -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#2A2A2A"
            app:strokeWidth="1dp"
            android:onClick="allowSysAppUpdateHandler">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mainactivity_button_allow_install_system_app"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tool_desc_allow_sysapp"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Row 4, Col 1: Fix unknown-source sensitive permissions -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#2A2A2A"
            app:strokeWidth="1dp"
            android:onClick="fixUnknownSourcePermissionsHandler">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mainactivity_button_fix_unknown_source_permission"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tool_desc_fix_unknown_source_permission"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Row 4, Col 2: VoiceAssist power wake fix -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#2A2A2A"
            app:strokeWidth="1dp"
            android:onClick="enableVoiceAssistPowerWakeFixHandler">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mainactivity_button_save_voiceassist_powerwake"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tool_desc_save_voiceassist_powerwake"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </GridLayout>

    <!-- Bottom Log Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_delete_error_log"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:onClick="deleteErrorLogHandler"
            android:text="@string/mainactivity_button_delete_error_log"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#333333"
            android:textColor="#888888" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_package_error_log"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:onClick="packageErrorLogHandler"
            android:text="@string/mainactivity_button_package_error_log"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#333333"
            android:textColor="#888888" />

    </LinearLayout>

    <!-- Hidden buttons for compatibility with onClick handlers -->
    <Button android:id="@+id/button_recheck_device_status" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <Button android:id="@+id/button_fix_permissions2" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <Button android:id="@+id/button_fix_permissions" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <Button android:id="@+id/button_clean_package_cache" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <Button android:id="@+id/button_reset_package_restriction" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <Button android:id="@+id/button_hide_theme_folder" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <Button android:id="@+id/button_allow_system_app_update" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <Button android:id="@+id/button_fix_unknown_source_permission" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <Button android:id="@+id/button_enable_voiceassist_powerwake_fix" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

</LinearLayout>
